.dropdown-content { display: none; position: absolute; top: 100%; right: 0; background: var(--bg-card-light); border: 1px solid rgba(0,0,0,0.06); border-radius: 12px; padding: 8px 0; min-width: 220px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); }
