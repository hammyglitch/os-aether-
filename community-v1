<script>
// INITIALIZE GSAP SCROLLTRIGGER ENGINE ENVIRONMENT
gsap.registerPlugin(ScrollTrigger);

// Nav Matrix Dynamic Background Color Switch logic
window.addEventListener("scroll", function() {
  const nav = document.getElementById("nav");
  if(window.scrollY > 40) {
    nav.classList.add("dark-nav");
  } else {
    nav.classList.remove("dark-nav");
  }
});

// Smooth GSAP Entry Staggers
gsap.from(".hero *", { y: 30, opacity: 0, duration: 0.8, stagger: 0.15, ease: "power3.out" });

// Map generic Card animations
gsap.utils.toArray(".animation-trigger").forEach(section => {
  gsap.from(section.querySelectorAll(".news-card, .svc-heading, .svc-body, .btn-primary, .sample-block"), {
    scrollTrigger: {
      trigger: section,
      start: "top 80%",
      toggleActions: "play none none none"
    },
    y: 40,
    opacity: 0,
    duration: 0.65,
    stagger: 0.15,
    ease: "power2.out"
  });
});

// Modal Intercept Controller Handlers
function openPopup() { document.getElementById("popup").classList.add("active"); }
function closePopup() {
  document.getElementById("popup").classList.remove("active");
  setTimeout(() => {
    document.getElementById("popup-form-content").style.display = "block";
    document.getElementById("popup-success").style.display = "none";
  }, 400);
}
document.getElementById("popup").addEventListener("click", function(e) {
  if(e.target === this) closePopup();
});
function submitPopup(e) {
  e.preventDefault();
  const btn = e.target.querySelector("button");
  btn.textContent = "Encoding Strategy Packet...";
  setTimeout(() => {
    document.getElementById("popup-form-content").style.display = "none";
    document.getElementById("popup-success").style.display = "block";
    setTimeout(closePopup, 3000);
  }, 1200);
}
</script>
