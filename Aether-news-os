<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Aether OS News — Global Intelligence Feed</title>
<meta name="description" content="Aether OS News: Politics, Cyber, Business, and Global affairs. Real-time intelligence for UK SMEs.">
<link rel="canonical" href="https://aetherbusinessarchitectsltd.uk/aether-news.html">
<link rel="icon" type="image/png" href="aether os logo v2.png">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;0,800;1,400&family=Fira+Code:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700;800&family=Orbitron:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {

    --blue:#005BFF;

    --blue:#006EFF;

    --blue-light:#5EA8FF;

    --blue-glow:rgba(0,110,255,.18);
    --bg: #F8F9FC;
    --white: #FFFFFF;
    --ink: #0B0E17;
    --ink2: #3C4260;
    --muted: #6B7280;
    --card-bg: #FFFFFF;
    --border: rgba(0,0,0,0.06);
    --cyan: #0088A8;
    --cyan-bright: #00E5FF;
    --gold: #C8A96E;
    --gold-warm: #E8CA9A;
    --red: #C00000;
    --green: #10B981;
    --violet: #8B5CF6;
    --serif: 'Cormorant Garamond', Georgia, serif;
    --mono: 'Fira Code', monospace;
    --inter: 'Inter', sans-serif;
    --orbitron: 'Orbitron', sans-serif;
    --radius: 14px;
    --shadow: 0 4px 24px rgba(0,0,0,0.06);
    --shadow-lg: 0 12px 48px rgba(0,0,0,0.1);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; overflow-x: hidden; }
body { background: var(--bg); color: var(--ink); font-family: var(--inter); font-size: 27px; line-height: 1.6; }
a { text-decoration: none; color: inherit; }

/* ═══ STROBE ═══ */
@keyframes strobeLeft {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
}
/* AETHER STROBE — Blue Knight Rider */
.strobe {
    background: linear-gradient(90deg, transparent 0%, #00d2ff 25%, #ffffff 50%, #00d2ff 75%, transparent 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: strobeLeft 2.5s linear infinite;
}
.strobe-gold {
    background: linear-gradient(90deg, transparent 0%, #c8a96e 25%, #ffffff 50%, #c8a96e 75%, transparent 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: strobeLeft 3s linear infinite;
}
.strobe-violet {
    background: linear-gradient(90deg, transparent 0%, #8B5CF6 25%, #ffffff 50%, #8B5CF6 75%, transparent 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: strobeLeft 2.8s linear infinite;
}
.strobe-green {
    background: linear-gradient(90deg, transparent 0%, #10B981 25%, #ffffff 50%, #10B981 75%, transparent 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: strobeLeft 3.2s linear infinite;
}
.strobe-red {
    background: linear-gradient(90deg, transparent 0%, #FF4D6D 25%, #ffffff 50%, #FF4D6D 75%, transparent 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: strobeLeft 2.6s linear infinite;
}

/* ═══ HEADER ═══ */
header {
    background: var(--blue);
    padding: 14px 24px;
    border-bottom: 3px solid var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    top: 0px; /* Adjust this to 0 if the header is above the ticker */
    z-index: 999; /* Keeps it above the scrolling content */
}
.logo-slot { height: 56px; display: flex; align-items: center; justify-content: center; margin-right: 16px; }
.logo-slot img { max-height: 56px; max-width: 100%; }
.masthead { display: flex; align-items: center; justify-content: center; overflow: hidden; position: sticky;top50 }
.logo-block { display: flex; align-items: center; gap: 3px; }
.logo-word { display: inline-flex; align-items: center; justify-content: center; font-size: 24px; font-weight: 900; letter-spacing: 1px; padding: 7px 10px; line-height: 1; text-transform: uppercase; border-radius: 4px; opacity: 0; }
.logo-aether {
    background: var(--ink); color: #fff;
    animation: slideInLeft 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.15s forwards;
}
.logo-os {
    background: var(--gold); color: var(--ink);
    animation: dropInTop 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.55s forwards,
               pulseGlow 2.4s ease-in-out 1.3s 2;
}
.logo-news {
    background: linear-gradient(135deg, var(--cyan) 0%, var(--violet) 100%); color: #fff;
    animation: slideInRight 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.15s forwards;
}
@keyframes slideInLeft {
    0%   { opacity: 0; transform: translateX(-160px) rotate(-4deg); }
    70%  { opacity: 1; }
    100% { opacity: 1; transform: translateX(0) rotate(0deg); }
}
@keyframes slideInRight {
    0%   { opacity: 0; transform: translateX(160px) rotate(4deg); }
    70%  { opacity: 1; }
    100% { opacity: 1; transform: translateX(0) rotate(0deg); }
}
@keyframes dropInTop {
    0%   { opacity: 0; transform: translateY(-40px) scale(0.6); }
    60%  { opacity: 1; transform: translateY(6px) scale(1.08); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
}
@keyframes pulseGlow {
    0%, 100% { box-shadow: 0 0 0 rgba(200,169,110,0); }
    50%      { box-shadow: 0 0 18px 4px rgba(200,169,110,0.55); }
}

/* ═══ NAV ═══ */
nav {

    background: var(--white);
    border-bottom: 2px solid var(--border);
    display: flex;
    justify-content: center;
    overflow-x: auto;
    overflow-y: visible;
    scrollbar-width: none;
    position: relative;
    top: 0;
    z-index: 1000;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
  /* New Blue to White Linear Gradient */
    background: linear-gradient(to right, #007BFF, #FFFFFF);
}
nav.scrolled{height:40px;max-height:60px;background:rgba(11,14,23,0.98);backdrop-filter:blur(10px);border-bottom:6px solid rgba(200,169,110,.15)}
.nav-brand{display:flex;align-items:center;gap:10px;text-decoration:none;color:#FFFFFF;height:100%}
.header-logo{width:38px;height:38px;aspect-ratio:1/1;object-fit:contain;display:block;border-radius:8px;flex-shrink:0;transition:all .3s}
nav.scrolled .header-logo{width:32px;height:32px}
.nav-brand-text{font-family:var(--serif);font-style:italic;font-size:2.5rem;color:;letter-spacing:.01em;white-space:nowrap}
.nav-brand-text em{font-style:normal;color:var(--gold)}
.nav-links{display:flex;gap:40px;list-style:none;align-items:center}.nav-links li{position:relative}.nav-links>li>a{font-size:.95rem;letter-spacing:.18em;text-transform:uppercase;color: #FFFFFF;text-decoration:none;transition:color .3s;white-space:nowrap}.nav-links>li>a:hover{color:var(--gold)}
.dropdown{position:relative;display:inline-block}.dropdown-content{display:none;position:absolute;background:var(--white);min-width:220px;box-shadow:0 8px 16px rgba(0,0,0,0.1);z-index:1;top:100%;left:0;border:1px solid rgba(200,169,110,0.3)}.dropdown-content a{color:var(--ink2);padding:12px 16px;text-decoration:none;display:block;font-size:10px;letter-spacing:1.5px;border-bottom:1px solid rgba(0,0,0,0.05)}.dropdown-content a:hover{background:rgba(200,169,110,0.06);color:var(--gold)}.dropdown:hover .dropdown-content{display:block}
.btn{display:inline-block;padding:14px 28px;font-family:var(--origin);font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;border:2px solid rgba(255,255,255,0.6);color:#000;background:transparent;transition:all .4s;cursor:pointer;border-radius:8px;font-weight:600}.btn:hover{background:#fff;color:var(--dark)}
.btn-cyan{display:inline-block;padding:14px 28px;font-family:var(--mono);font-size:.64rem;letter-spacing:.28em;text-transform:uppercase;text-decoration:none;border:1px solid var(--cyan);color:var(--cyan);background:transparent;transition:.35s ease;position:relative;overflow:hidden;animation:ctaBorderPulse 3.5s ease-in-out infinite}.btn-cyan:hover{background:var(--cyan);color:var(--dark);transform:translateY(-2px)}
@keyframes ctaBorderPulse{0%,100%{box-shadow:0 0 0 rgba(0,200,220,0)}50%{box-shadow:0 0 20px rgba(0,200,220,.32)}}
nav::-webkit-scrollbar { display: none; }
nav a {
    color: var(--ink2);
    text-decoration: none;
    padding: 10px 24px;
    font-family: var(--orbitron);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
    border-bottom: 3px solid transparent;
    transition: all 0.2s;
    display: block;
}
nav a:hover { color: var(--gold); border-bottom-color: var(--gold); }
nav a.active { color: var(--gold); border-bottom-color: var(--gold); }

/* ═══ DROPDOWN ═══ */
.nav-dropdown { position: relative; }
.dropdown-menu {
    position: absolute; top: 100%; left: 0;
    background: var(--white); border: 1px solid var(--border);
    box-shadow: var(--shadow-lg); min-width: 200px;
    display: none; flex-direction: column; z-index: 50;
    border-radius: 0 0 var(--radius) var(--radius);
}
.nav-dropdown:hover .dropdown-menu,
.nav-dropdown:focus-within .dropdown-menu { display: flex; }
.dropdown-menu a {
    padding: 12px 20px; border-bottom: 1px solid var(--border);
    font-size: 0.72rem; font-family: var(--mono); letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--ink2); font-weight: 500;
}
.dropdown-menu a:hover { background: var(--bg); color: var(--gold); }

/* ═══ TICKER ═══ */
.ticker-bar {
    background: var(--red); 
    color: #fff; 
    display: flex;
    align-items: center; 
    overflow: hidden; 
    height: 40px; 
    position: sticky;
    top: 35px; /* Added 'px' here */
    z-index: 1000; 
}

.ticker-label {
    background: rgba(0,0,0,0.2); 
    padding: 0 16px; 
    height: 100%;
    display: flex; 
    align-items: center; 
    font-family: var(--orbitron);
    font-size: 0.7rem; 
    font-weight: 700; 
    letter-spacing: 0.1em;
    text-transform: uppercase; 
    white-space: nowrap; 
    flex-shrink: 0;
}

.ticker-scroll { 
    overflow: hidden; 
    flex: 1; 
}

.ticker-inner {
    display: inline-block; 
    white-space: nowrap;
    animation: tickerScroll 35s linear infinite; 
    padding-left: 100%;
}

.ticker-inner span { 
    margin-right: 60px; 
    font-family: var(--mono); 
    font-size: 1.15rem; 
    font-weight: 900; 
}

.ticker-inner span::before { 
    content: '\25CF'; 
    margin-right: 10px; 
    opacity: 0.6; 
}

@keyframes tickerScroll {
    from { transform: translateX(0); }
    to { transform: translateX(-100%); }
}
/* ════════════════════════════════════════════════
   SCROLLING INTELLIGENCE CARDS
   AETHER News OS v5
════════════════════════════════════════════════ */

.scroll-cards-bar{

    background:var(--black);
    border-bottom:1px solid var(--border);
    padding:16px 0;
    overflow:hidden;
    position:relative;

}

.scroll-cards-inner{

    display:flex;
    gap:16px;
    width:max-content;
    padding:0 24px;
    animation:scrollCards 40s linear infinite;

}

.scroll-cards-inner:hover{

    animation-play-state:paused;

}

@keyframes scrollCards{

    from{
        transform:translateX(0);
    }

    to{
        transform:translateX(-50%);
    }

}


/*═══════════════════════════════════════
    INTELLIGENCE CARD
═══════════════════════════════════════*/

.scroll-card{

    min-width:280px;
    max-width:300px;

    background:
    linear-gradient(
        135deg,
        var(--blue-glow) 0%,
        rgba(0,110,255,.08) 18%,
        #ffffff 42%,
        #ffffff 100%
    );

    border:1px solid rgba(0,110,255,.15);

    border-radius:var(--radius);

    padding:16px;

    position:relative;

    overflow:hidden;

    cursor:pointer;

    flex-shrink:0;

    transition:
        transform .35s ease,
        box-shadow .35s ease,
        border-color .35s ease;

    box-shadow:
        0 6px 18px rgba(0,20,60,.10);

}


/* Blue Intelligence Accent */

.scroll-card::before{

    content:"";

    position:absolute;

    top:0;
    left:0;
    right:0;

    height:4px;

    background:linear-gradient(
        90deg,
        var(--blue),
        var(--blue-light)
    );

}


/*═══════════════════════════════════════
    HOVER
═══════════════════════════════════════*/

.scroll-card:hover{

    transform:
        translateY(-8px)
        scale(1.04);

    border-color:var(--gold);

    box-shadow:

        0 18px 40px rgba(0,30,80,.18),

        0 0 18px rgba(0,110,255,.25),

        0 0 10px rgba(200,169,110,.25);

    z-index:20;

}


/*═══════════════════════════════════════
    CATEGORY TAGS
═══════════════════════════════════════*/

.scroll-card .sc-tag{

    display:inline-block;

    font-family:var(--mono);

    font-size:.60rem;

    font-weight:700;

    letter-spacing:.12em;

    text-transform:uppercase;

    padding:4px 10px;

    border-radius:20px;

    margin-bottom:10px;

}

.scroll-card .sc-tag.politics{

    background:rgba(139,92,246,.12);

    color:var(--violet);

}

.scroll-card .sc-tag.cyber{

    background:rgba(0,110,255,.12);

    color:var(--blue);

}

.scroll-card .sc-tag.business{

    background:rgba(16,185,129,.12);

    color:var(--green);

}

.scroll-card .sc-tag.tech{

    background:rgba(200,169,110,.12);

    color:var(--gold);

}

.scroll-card .sc-tag.defence{

    background:rgba(255,77,109,.12);

    color:var(--red);

}


/*═══════════════════════════════════════
    TITLE
═══════════════════════════════════════*/

.scroll-card h3{

    margin:0 0 8px;

    font-family:var(--serif);

    font-size:1rem;

    font-weight:700;

    line-height:1.35;

    color:var(--ink);

    transition:all .3s ease;

}

.scroll-card:hover h3{

    font-size:1.12rem;

    color:#000;

}


/*═══════════════════════════════════════
    SUMMARY
═══════════════════════════════════════*/

.scroll-card p{

    margin:0;

    font-size:.82rem;

    line-height:1.55;

    color:var(--muted);

    transition:all .3s ease;

}

.scroll-card:hover p{

    font-size:.92rem;

    color:var(--ink);

}


/*═══════════════════════════════════════
    TIME
═══════════════════════════════════════*/

.scroll-card .sc-time{

    margin-top:12px;

    font-family:var(--mono);

    font-size:.65rem;

    letter-spacing:.08em;

    color:var(--muted);

}
/* ═══ MAIN CONTAINER ═══ */
.main-container {
    max-width: 1440px;
    margin: 28px auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 400px 1fr 280px;
    gap: 28px;
}
@media (max-width: 1100px) {
    .main-container { grid-template-columns: 1fr 1fr; }
    .right-column { grid-column: span 2; }
}
@media (max-width: 680px) {
    .main-container { grid-template-columns: 1fr; padding: 0 12px; }
    .right-column { grid-column: span 1; }
}

/* ═══ COLUMNS ═══ */
.left-column, .center-column, .right-column {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
}
/* Left (video) and right (most read) stay pinned + height-capped so they
   never leave a tall blank gap while the center stories column runs long. */
.left-column, .right-column {
    position: sticky;
    top: 20px;
    align-self: start;
    max-height: calc(100vh - 40px);
    overflow-y: auto;
    scrollbar-width: thin;
}
@media (max-width: 1100px) {
    .left-column, .right-column { position: static; max-height: none; overflow-y: visible; }
}
.col-header {
    padding: 14px 18px;
    background: var(--bg);
    border-bottom: 2px solid var(--gold);
    font-family: var(--orbitron);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink);
}

/* ═══ VIDEO BLOCK ═══ */
.video-block { position: relative; }
.video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    background: var(--ink);
    overflow: hidden;
}
.video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
}
.video-error-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1a1a2e 0%, #0B0E17 100%);
}
.video-error-fallback .play-btn {
    width: 72px; height: 72px;
    border-radius: 50%;
    background: rgba(200, 169, 110, 0.2);
    border: 3px solid var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
    transition: all 0.3s;
}
.video-error-fallback .play-btn:hover { background: rgba(200,169,110,0.4); transform: scale(1.1); }
.video-error-fallback .play-btn::after {
    content: ''; width: 0; height: 0;
    border-left: 22px solid var(--gold);
    border-top: 14px solid transparent;
    border-bottom: 14px solid transparent;
    margin-left: 6px;
}
.video-error-fallback a {
    color: var(--gold);
    font-family: var(--mono);
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
}
.video-error-fallback a:hover { text-decoration: underline; }
.video-caption { padding: 14px 18px; border-top: 3px solid var(--gold); background: var(--bg); }
.video-caption .section-tag { color: var(--gold); }
.video-caption h2 {
    font-family: var(--serif);
    font-size: 1.35rem;
    font-weight: 700;
    margin: 6px 0;
    color: var(--ink);
    line-height: 1.25;
}
.video-caption p { color: var(--muted); font-size: 0.9rem; }

/* ═══ STORY CARDS ═══ */
.story {
    padding: 16px 18px;
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 6px;
}
.story:last-child { border-bottom: none; }
.story.featured { border-left: 4px solid var(--red); background: var(--bg); }
.story.politics { border-left: 3px solid var(--violet); }
.story.cyber { border-left: 3px solid var(--cyan); }
.story.business { border-left: 3px solid var(--green); }
.story.tech { border-left: 3px solid var(--gold); }
.story.defence { border-left: 3px solid var(--red); }
.section-tag {
    font-family: var(--mono);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
}
.section-tag.politics { color: var(--violet); }
.section-tag.cyber { color: var(--cyan); }
.section-tag.business { color: var(--green); }
.section-tag.tech { color: var(--gold); }
.section-tag.feature { color: var(--gold); }
.section-tag.defence { color: var(--red); }
.story h2 {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.3;
}
.story h2 a { color: var(--ink); transition: color 0.2s; }
.story h2 a:hover { color: var(--gold); }
.story p { font-size: 0.9rem; color: var(--muted); line-height: 1.55; }
.story-meta { font-family: var(--mono); font-size: 0.72rem; color: var(--muted); letter-spacing: 0.03em; }

/* ═══ MOST READ ═══ */
.most-read-item {
    padding: 14px 18px;
    border-bottom: 1px solid var(--border);
    display: flex;
    gap: 12px;
    align-items: flex-start;
    transition: background 0.2s;
}
.most-read-item:last-child { border-bottom: none; }
.most-read-item:hover { background: var(--bg); }
.most-read-num {
    font-family: var(--orbitron);
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
    min-width: 30px;
}
.most-read-title {
    font-family: var(--serif);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.35;
    cursor: pointer;
    transition: color 0.2s;
}
.most-read-title:hover { color: var(--gold); }

/* ═══ SCRAPER SECTIONS ═══ */
.scraper-section {
    padding: 16px 18px;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
}
.scraper-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
}
.scraper-num {
    font-family: var(--orbitron);
    font-size: 0.6rem;
    font-weight: 700;
    color: #fff;
    background: var(--gold);
    padding: 4px 10px;
    border-radius: 4px;
    letter-spacing: 0.1em;
}
.scraper-title {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
}
.scraper-content ul {
    list-style: none;
    padding: 0;
    margin: 0;
}
